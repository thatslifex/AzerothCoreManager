<ui:FluentWindow x:Class="AzerothCoreManager.Windows.BackupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Backup Manager"
        Width="800" Height="600"
        MinWidth="600" MinHeight="450">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Backup Manager" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            <Button Content="?" Width="28" Height="28" Margin="8,0,0,0"
                    Click="HelpButton_Click" ToolTip="Open Wiki Help"/>
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="CreateBackupButton" Content="Create Backup Now" Width="140" Height="32"
                    Margin="0,0,8,0" Click="CreateBackupButton_Click"
                    Background="#FF2D5A2D" Foreground="White" FontWeight="SemiBold"/>
            <Button x:Name="RestoreButton" Content="Restore Selected" Width="130" Height="32"
                    Margin="0,0,8,0" Click="RestoreButton_Click"/>
            <Button x:Name="RefreshListButton" Content="Refresh List" Width="100" Height="32"
                    Click="RefreshListButton_Click"/>
            <TextBlock x:Name="StatusText" Text="" Foreground="#FFAAAAAA" FontSize="12"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Backup directory -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Backup Dir:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" x:Name="BackupDirBox"
                     Background="#FF0D0D1A" Foreground="White"
                     BorderBrush="#FF333355" BorderThickness="1" FontSize="12"/>
            <Button Grid.Column="2" Content="..." Width="32" Height="24" Margin="6,0,0,0"
                    Click="BrowseDir_Click"/>
        </Grid>

        <!-- Backup list -->
        <Border Grid.Row="3" Background="#CC1A1A2E" CornerRadius="6" Padding="8">
            <DataGrid x:Name="BackupGrid" AutoGenerateColumns="False"
                      Background="Transparent" Foreground="White"
                      RowBackground="#FF1A1A2E" BorderThickness="0"
                      IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="280"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding Size, StringFormat='{}{0:N0} bytes'}" Width="100"/>
                    <DataGridTextColumn Header="Created" Binding="{Binding Created, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Live Log -->
        <Border Grid.Row="4" Background="#CC1A1A2E" CornerRadius="6" Padding="8"
                Height="120" Margin="0,8,0,0">
            <ScrollViewer>
                <TextBox x:Name="LogOutput"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#FFCCCCCC"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderThickness="0"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </Border>
    </Grid>
</ui:FluentWindow>
