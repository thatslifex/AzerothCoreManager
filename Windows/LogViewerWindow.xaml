<ui:FluentWindow x:Class="AzerothCoreManager.Windows.LogViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Log Viewer"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Log Viewer" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            <Button Content="?" Width="28" Height="28" Margin="8,0,0,0"
                    Click="HelpButton_Click" ToolTip="Open Wiki Help"/>
        </StackPanel>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Log File:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Grid.Column="1" x:Name="LogFileCombo" Height="26"
                      Background="#FF0D0D1A" Foreground="White"
                      BorderBrush="#FF333355"
                      SelectionChanged="LogFileCombo_SelectionChanged"/>
            <TextBlock Grid.Column="2" Text="Filter:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center" Margin="12,0,8,0"/>
            <TextBox Grid.Column="3" x:Name="FilterBox"
                     Background="#FF0D0D1A" Foreground="White"
                     BorderBrush="#FF333355" BorderThickness="1" FontSize="12"
                     KeyDown="FilterBox_KeyDown"/>
            <Button Grid.Column="4" x:Name="FilterButton" Content="Filter" Width="60" Height="26"
                    Margin="8,0,8,0" Click="FilterButton_Click"/>
            <Button Grid.Column="5" x:Name="RefreshButton" Content="Refresh" Width="70" Height="26"
                    Click="RefreshButton_Click"/>
        </Grid>

        <!-- Status -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="StatusText" Text="" Foreground="#FFAAAAAA" FontSize="12"/>
            <Button x:Name="ClearButton" Content="Clear" Width="60" Height="22"
                    Margin="12,0,0,0" Click="ClearButton_Click"/>
            <CheckBox x:Name="AutoRefreshCheck" Content="Auto-refresh (5s)" 
                      Foreground="White" FontSize="12" Margin="12,0,0,0"
                      Checked="AutoRefreshCheck_Changed" Unchecked="AutoRefreshCheck_Changed"/>
        </StackPanel>

        <!-- Log content -->
        <Border Grid.Row="3" Background="#CC1A1A2E" CornerRadius="6" Padding="8">
            <ScrollViewer x:Name="LogScroller" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="LogContent"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#FFCCCCCC"
                         FontFamily="Consolas"
                         FontSize="12"
                         BorderThickness="0"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>
    </Grid>
</ui:FluentWindow>
