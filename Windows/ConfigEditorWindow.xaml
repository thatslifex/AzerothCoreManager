<ui:FluentWindow x:Class="AzerothCoreManager.Windows.ConfigEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Config Editor"
        Width="900" Height="650"
        MinWidth="700" MinHeight="500">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Config Editor" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            <Button Content="?" Width="28" Height="28" Margin="8,0,0,0"
                    Click="HelpButton_Click" ToolTip="Open Wiki Help"/>
        </StackPanel>

        <!-- File selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="File:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="FileCombo" Width="220" Height="26"
                      Background="#FF0D0D1A" Foreground="White"
                      BorderBrush="#FF333355"
                      SelectionChanged="FileCombo_SelectionChanged">
                <ComboBoxItem Content="worldserver.conf" Tag="worldserver.conf" IsSelected="True"/>
                <ComboBoxItem Content="authserver.conf" Tag="authserver.conf"/>
            </ComboBox>
            <Button x:Name="RefreshButton" Content="Refresh" Width="70" Height="26"
                    Margin="8,0,8,0" Click="RefreshButton_Click"/>
            <Button x:Name="SaveButton" Content="Save" Width="60" Height="26"
                    Click="SaveButton_Click"
                    Background="#FF2D5A2D" Foreground="White"/>
            <TextBlock x:Name="StatusText" Text="" Foreground="#FFAAAAAA" FontSize="12"
                       VerticalAlignment="Center" Margin="12,0,0,0"/>
        </StackPanel>

        <!-- Search -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SearchBox"
                     Background="#FF0D0D1A" Foreground="White"
                     BorderBrush="#FF333355" BorderThickness="1" FontSize="12"
                     KeyDown="SearchBox_KeyDown"/>
            <Button Grid.Column="1" x:Name="SearchButton" Content="Find" Width="60" Height="26"
                    Margin="8,0,0,0" Click="SearchButton_Click"/>
        </Grid>

        <!-- Editor -->
        <Border Grid.Row="3" Background="#CC1A1A2E" CornerRadius="6" Padding="8">
            <ScrollViewer x:Name="EditorScroller" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="EditorBox"
                         Background="Transparent"
                         Foreground="#FFCCCCCC"
                         FontFamily="Consolas"
                         FontSize="13"
                         BorderThickness="0"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled"/>
            </ScrollViewer>
        </Border>

        <!-- Help text -->
        <TextBlock Grid.Row="4" Text="Edit values directly. Lines starting with # are comments. Save writes back to the .conf file."
                   Foreground="#FF666666" FontSize="11" Margin="0,6,0,0"/>
    </Grid>
</ui:FluentWindow>
