<Page x:Class="AzerothCoreManager.Pages.ModuleManagerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Module Manager">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Module Manager" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            <Button Content="?" Width="28" Height="28" Margin="8,0,0,0"
                    Click="HelpButton_Click" ToolTip="Open Wiki Help"/>
        </StackPanel>

        <!-- Search + Actions -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="SearchBox" 
                     Background="#FF0D0D1A" Foreground="White"
                     BorderBrush="#FF333355" BorderThickness="1"
                     FontSize="13" Margin="0,0,8,0"
                     KeyDown="SearchBox_KeyDown"/>
            <Button Grid.Column="1" x:Name="SearchButton" Content="Search GitHub" 
                    Width="120" Height="28" Margin="0,0,6,0"
                    Click="SearchButton_Click"/>
            <Button Grid.Column="2" x:Name="RefreshLocalButton" Content="Refresh Local" 
                    Width="110" Height="28" Margin="0,0,6,0"
                    Click="RefreshLocalButton_Click"/>
            <Button Grid.Column="3" x:Name="RebuildButton" Content="Rebuild CMake" 
                    Width="120" Height="28"
                    Click="RebuildButton_Click"/>
        </Grid>

        <!-- Tab switcher -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="CatalogTab" Content="GitHub Catalog" Width="130" Height="28"
                    Margin="0,0,6,0" Click="CatalogTab_Click"
                    Background="#FF2D2D5A" Foreground="White" FontWeight="SemiBold"/>
            <Button x:Name="InstalledTab" Content="Installed Modules" Width="130" Height="28"
                    Click="InstalledTab_Click"/>
        </StackPanel>

        <!-- Module List -->
        <Border Grid.Row="3" Background="#CC1A1A2E" CornerRadius="6" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Catalog view -->
                <ScrollViewer Grid.Row="0" x:Name="CatalogScroller" Visibility="Visible">
                    <ItemsControl x:Name="CatalogList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,8">
                                    <Grid Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                                       Foreground="White" FontSize="14"/>
                                            <TextBlock Text="{Binding Description}" 
                                                       Foreground="#FFAAAAAA" FontSize="12"
                                                       TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="⭐ " Foreground="#FFFFCC00" FontSize="11"/>
                                                <TextBlock Text="{Binding Stars}" Foreground="#FFCCCCCC" FontSize="11"/>
                                                <TextBlock Text="  Updated: " Foreground="#FF888888" FontSize="11" Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd}'}" 
                                                           Foreground="#FFCCCCCC" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Button Content="Install" Width="80" Height="28"
                                                    Tag="{Binding}" Click="InstallButton_Click"/>
                                            <Button Content="Open GitHub" Width="80" Height="28"
                                                    Margin="0,4,0,0" Tag="{Binding}" Click="OpenGitHubButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Installed view -->
                <ScrollViewer Grid.Row="0" x:Name="InstalledScroller" Visibility="Collapsed">
                    <ItemsControl x:Name="InstalledList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,0,0,8">
                                    <Grid Margin="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" 
                                                           Foreground="White" FontSize="14"/>
                                                <TextBlock Text=" (Active)" Foreground="#FF00CC00" FontSize="11"
                                                           Margin="6,0,0,0" Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Path}" Foreground="#FF666666" FontSize="11"
                                                       FontFamily="Consolas" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Button Content="Update" Width="80" Height="28"
                                                    Tag="{Binding}" Click="UpdateLocalButton_Click"/>
                                            <Button Content="Remove" Width="80" Height="28"
                                                    Margin="0,4,0,0" Tag="{Binding}" Click="RemoveButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Status text when lists are empty -->
                <TextBlock Grid.Row="0" x:Name="EmptyText" Text=""
                           Foreground="#FF888888" FontSize="14" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="Collapsed"/>
            </Grid>
        </Border>

        <!-- Live Log -->
        <Border Grid.Row="4" Background="#CC1A1A2E" CornerRadius="6" Padding="8"
                Height="150" Margin="0,8,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Module Log" FontWeight="SemiBold" Foreground="White"/>
                    <Button x:Name="ClearLogButton" Content="Clear" Width="60" Height="22"
                            Margin="12,0,0,0" Click="ClearLogButton_Click"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1">
                    <TextBox x:Name="LogOutput"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#FFCCCCCC"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
