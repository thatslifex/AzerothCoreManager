<Page x:Class="AzerothCoreManager.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:fui="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
      Title="Dashboard">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Dashboard"
                       FontSize="24" FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center" />
            <Button Content="?" Width="28" Height="28"
                    Margin="8,0,0,0"
                    Click="HelpButton_Click"
                    ToolTip="Open Wiki Help"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" />
        </StackPanel>

        <!-- Server Status Cards -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,12">
            <ui:Card Margin="0,0,12,0" Width="200">
                <StackPanel Margin="12">
                    <TextBlock Text="Authserver" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="AuthStatus" Text="Offline" Foreground="#FF888888" FontSize="14" />
                </StackPanel>
            </ui:Card>
            <ui:Card Margin="0,0,12,0" Width="200">
                <StackPanel Margin="12">
                    <TextBlock Text="Worldserver" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="WorldStatus" Text="Offline" Foreground="#FF888888" FontSize="14" />
                </StackPanel>
            </ui:Card>
            <ui:Card Margin="0,0,12,0" Width="200">
                <StackPanel Margin="12">
                    <TextBlock Text="MySQL" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="MySqlStatus" Text="Offline" Foreground="#FF888888" FontSize="14" />
                </StackPanel>
            </ui:Card>
            <ui:Card Width="200">
                <StackPanel Margin="12">
                    <TextBlock Text="Players Online" FontWeight="SemiBold" Foreground="White" />
                    <TextBlock x:Name="PlayerCount" Text="0" Foreground="#FF888888" FontSize="14" />
                </StackPanel>
            </ui:Card>
        </WrapPanel>

        <!-- Worldserver Console -->
        <Border Grid.Row="2" Background="#CC1A1A2E" CornerRadius="6" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Worldserver Console"
                           FontWeight="SemiBold" Foreground="White" Margin="0,0,0,6" />

                <ScrollViewer Grid.Row="1" x:Name="ConsoleScroller">
                    <TextBox x:Name="ConsoleOutput"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#FFCCCCCC"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="&gt;"
                               Foreground="#FF00FF00"
                               FontFamily="Consolas"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />

                    <TextBox Grid.Column="1" x:Name="CommandInput"
                             Background="#FF0D0D1A"
                             Foreground="White"
                             FontFamily="Consolas"
                             FontSize="12"
                             BorderBrush="#FF333355"
                             BorderThickness="1" />

                    <Button Grid.Column="2" x:Name="SendButton"
                            Content="Send"
                            Width="60" Height="26"
                            Margin="6,0,0,0"
                            Click="SendButton_Click"
                            Background="#FF2D2D5A"
                            Foreground="White" />
                </Grid>
            </Grid>
        </Border>

        <!-- Quick Actions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="StartAllButton" Content="Start All"
                    Width="100" Margin="0,0,8,0"
                    Click="StartAllButton_Click" />
            <Button x:Name="StopAllButton" Content="Stop All"
                    Width="100" Margin="0,0,8,0"
                    Click="StopAllButton_Click" />
            <Button x:Name="BackupButton" Content="Backup Now"
                    Width="110" Margin="0,0,8,0"
                    Click="BackupButton_Click" />
            <Button x:Name="CheckUpdateButton" Content="Check Updates"
                    Width="120"
                    Click="CheckUpdateButton_Click" />
        </StackPanel>
    </Grid>
</Page>
