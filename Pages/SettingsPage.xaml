<Page
    x:Class="AzerothCoreManager.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,16"
                Orientation="Horizontal">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="White"
                    Text="Settings" />
                <Button
                    Width="28"
                    Height="28"
                    Margin="8,0,0,0"
                    Click="HelpButton_Click"
                    Content="?"
                    ToolTip="Open Wiki Help" />
            </StackPanel>

            <!--  Server Paths  -->
            <ui:Card Grid.Row="1" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Server Paths" />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Source Path:" />
                        <TextBox
                            x:Name="SourcePathBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                        <Button
                            Grid.Column="2"
                            Width="32"
                            Height="24"
                            Margin="6,0,0,0"
                            Click="BrowseSourcePath_Click"
                            Content="..." />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Build Path:" />
                        <TextBox
                            x:Name="BuildPathBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                        <Button
                            Grid.Column="2"
                            Width="32"
                            Height="24"
                            Margin="6,0,0,0"
                            Click="BrowseBuildPath_Click"
                            Content="..." />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Server Path:" />
                        <TextBox
                            x:Name="ServerPathBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                        <Button
                            Grid.Column="2"
                            Width="32"
                            Height="24"
                            Margin="6,0,0,0"
                            Click="BrowseServerPath_Click"
                            Content="..." />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!--  MySQL + SOAP  -->
            <ui:Card Grid.Row="2" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="MySQL &amp; SOAP" />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="MySQL Host:" />
                        <TextBox
                            x:Name="MySqlHostBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                        <TextBlock
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Port:" />
                        <TextBox
                            x:Name="MySqlPortBox"
                            Grid.Column="3"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Root Password:" />
                        <TextBox
                            x:Name="MySqlRootPassBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="SOAP User:" />
                        <TextBox
                            x:Name="SoapUserBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="SOAP Password:" />
                        <TextBox
                            x:Name="SoapPassBox"
                            Grid.Column="1"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            BorderThickness="1"
                            FontSize="12"
                            Foreground="White" />
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!--  Appearance  -->
            <ui:Card Grid.Row="3" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Appearance" />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Theme:" />
                        <ComboBox
                            x:Name="ThemeCombo"
                            Grid.Column="1"
                            Width="160"
                            Height="26"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            Foreground="White"
                            SelectionChanged="ThemeCombo_SelectionChanged">
                            <ComboBoxItem Content="Dark" />
                            <ComboBoxItem Content="Light" />
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Language:" />
                        <ComboBox
                            x:Name="LanguageCombo"
                            Grid.Column="1"
                            Width="160"
                            Height="26"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            Foreground="White"
                            SelectionChanged="LanguageCombo_SelectionChanged">
                            <ComboBoxItem Content="English" Tag="en" />
                            <ComboBoxItem Content="Deutsch" Tag="de" />
                            <ComboBoxItem Content="Français" Tag="fr" />
                            <ComboBoxItem Content="Español" Tag="es" />
                            <ComboBoxItem Content="中文" Tag="zh" />
                            <ComboBoxItem Content="Русский" Tag="ru" />
                        </ComboBox>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Background:" />
                        <ComboBox
                            x:Name="BackgroundCombo"
                            Grid.Column="1"
                            Width="200"
                            Height="26"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            Foreground="White">
                            <ComboBoxItem
                                Content="WotLK (Default)"
                                IsSelected="True"
                                Tag="background_wow.jpg" />
                            <ComboBoxItem Content="The Burning Crusade" Tag="background_wow_bc.jpg" />
                            <ComboBoxItem Content="Cataclysm" Tag="background_wow_cata.jpg" />
                            <ComboBoxItem Content="Mists of Pandaria" Tag="background_wow_mop.jpg" />
                            <ComboBoxItem Content="Warlords of Draenor" Tag="background_wow_wod.jpg" />
                            <ComboBoxItem Content="BlizzCon" Tag="background_blizzcon.jpg" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ui:Card>

            <!--  Updates & Behavior  -->
            <ui:Card Grid.Row="4" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Updates &amp; Behavior" />

                    <CheckBox
                        x:Name="AutoUpdateCheck"
                        Margin="0,0,0,6"
                        Content="Automatically check for updates"
                        FontSize="12"
                        Foreground="White" />

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="#FFAAAAAA"
                            Text="Update Channel:" />
                        <ComboBox
                            x:Name="UpdateChannelCombo"
                            Grid.Column="1"
                            Width="120"
                            Height="26"
                            Background="#FF0D0D1A"
                            BorderBrush="#FF333355"
                            Foreground="White">
                            <ComboBoxItem
                                Content="Stable"
                                IsSelected="True"
                                Tag="stable" />
                            <ComboBoxItem Content="Beta" Tag="beta" />
                        </ComboBox>
                    </Grid>

                    <CheckBox
                        x:Name="AutoRestartCheck"
                        Margin="0,6,0,0"
                        Content="Auto-restart server on crash"
                        FontSize="12"
                        Foreground="White" />
                </StackPanel>
            </ui:Card>

            <!--  Export / Import  -->
            <ui:Card Grid.Row="5" Margin="0,0,0,12">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="Backup &amp; Restore Settings" />
                    <StackPanel Orientation="Horizontal">
                        <Button
                            x:Name="ExportButton"
                            Width="120"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="ExportButton_Click"
                            Content="Export Settings" />
                        <Button
                            x:Name="ImportButton"
                            Width="120"
                            Height="28"
                            Click="ImportButton_Click"
                            Content="Import Settings" />
                    </StackPanel>
                </StackPanel>
            </ui:Card>

            <!--  Save + About  -->
            <Grid Grid.Row="6" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="SaveButton"
                    Grid.Column="1"
                    Width="130"
                    Height="36"
                    Background="#FF2D5A2D"
                    Click="SaveButton_Click"
                    Content="Save Settings"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Foreground="White" />
            </Grid>

            <!--  About  -->
            <ui:Card Grid.Row="7">
                <StackPanel Margin="12">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="About" />
                    <TextBlock
                        FontSize="13"
                        Foreground="White"
                        Text="AzerothCore Manager" />
                    <TextBlock
                        x:Name="VersionText"
                        Margin="0,2,0,0"
                        FontSize="12"
                        Foreground="#FFAAAAAA"
                        Text="Version 0.5.0" />
                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="11"
                        Foreground="#FF888888"
                        Text="Built with WPF UI 4.3.0, .NET 10, MySqlConnector 2.6.0" />
                    <TextBlock
                        Margin="0,2,0,0"
                        FontSize="11"
                        Foreground="#FF666666"
                        Text="© 2026 thatslifex" />
                    <TextBlock Margin="0,8,0,0">
                        <Hyperlink
                            x:Name="GitHubLink"
                            FontSize="11"
                            Foreground="#FF4488FF"
                            NavigateUri="https://github.com/thatslifex/AzerothCoreManager"
                            RequestNavigate="GitHubLink_RequestNavigate">
                            github.com/thatslifex/AzerothCoreManager
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </ui:Card>
        </Grid>
    </ScrollViewer>
</Page>
