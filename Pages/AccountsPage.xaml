<Page x:Class="AzerothCoreManager.Pages.AccountsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Accounts">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Accounts &amp; Community" FontSize="24" FontWeight="SemiBold" Foreground="White"/>
            <Button Content="?" Width="28" Height="28" Margin="8,0,0,0"
                    Click="HelpButton_Click" ToolTip="Open Wiki Help"/>
        </StackPanel>

        <!-- Tab switcher -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ActivityTab" Content="Player Activity" Width="120" Height="28"
                    Margin="0,0,6,0" Click="ActivityTab_Click"
                    Background="#FF2D2D5A" Foreground="White" FontWeight="SemiBold"/>
            <Button x:Name="MassCreateTab" Content="Mass Create" Width="110" Height="28"
                    Margin="0,0,6,0" Click="MassCreateTab_Click"/>
            <Button x:Name="AuditTab" Content="GM Audit Log" Width="110" Height="28"
                    Click="AuditTab_Click"/>
        </StackPanel>

        <!-- Refresh -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="RefreshButton" Content="Refresh" Width="80" Height="28"
                    Click="RefreshButton_Click"/>
        </StackPanel>

        <!-- Content area -->
        <Border Grid.Row="3" Background="#CC1A1A2E" CornerRadius="6" Padding="8">
            <Grid>
                <!-- Player Activity view -->
                <ScrollViewer x:Name="ActivityScroller" Visibility="Visible">
                    <DataGrid x:Name="ActivityGrid" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="White"
                              RowBackground="#FF1A1A2E" BorderThickness="0"
                              IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Account" Binding="{Binding Username}" Width="140"/>
                            <DataGridTextColumn Header="Characters" Binding="{Binding CharacterCount}" Width="80"/>
                            <DataGridTextColumn Header="Total Playtime" Binding="{Binding TotalPlaytime, StringFormat='{}{0:N0}s'}" Width="110"/>
                            <DataGridTextColumn Header="Last Login" Binding="{Binding LastLogin, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                            <DataGridTextColumn Header="Last IP" Binding="{Binding LastIp}" Width="130"/>
                            <DataGridTextColumn Header="Join Date" Binding="{Binding JoinDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100"/>
                            <DataGridTextColumn Header="GM Level" Binding="{Binding GmLevel}" Width="70"/>
                            <DataGridCheckBoxColumn Header="Locked" Binding="{Binding Locked}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>

                <!-- Mass Create view -->
                <Grid x:Name="MassCreateView" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Mass Account Creation" FontWeight="SemiBold" 
                               Foreground="White" FontSize="14" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Base Username:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="BaseUsernameBox" Text="player"
                                 Background="#FF0D0D1A" Foreground="White"
                                 BorderBrush="#FF333355" BorderThickness="1" FontSize="13"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Password:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="MassPasswordBox" Text="password123"
                                 Background="#FF0D0D1A" Foreground="White"
                                 BorderBrush="#FF333355" BorderThickness="1" FontSize="13"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Count:" Foreground="#FFAAAAAA" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBox x:Name="CountBox" Text="10" Width="60"
                                     Background="#FF0D0D1A" Foreground="White"
                                     BorderBrush="#FF333355" BorderThickness="1" FontSize="13"/>
                            <TextBlock Text="(creates player1..playerN)" Foreground="#FF666666" 
                                       FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="CreateMassButton" Content="Create Accounts" Width="130" Height="32"
                                Click="CreateMassButton_Click"
                                Background="#FF2D5A2D" Foreground="White" FontWeight="SemiBold"/>
                        <TextBlock x:Name="MassStatus" Text="" Foreground="#FFAAAAAA" FontSize="12"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>

                    <Border Grid.Row="5" Background="#CC0D0D1A" CornerRadius="4" Padding="8">
                        <ScrollViewer>
                            <TextBox x:Name="MassLog"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     Foreground="#FFCCCCCC"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- GM Audit Log view -->
                <ScrollViewer x:Name="AuditScroller" Visibility="Collapsed">
                    <DataGrid x:Name="AuditGrid" AutoGenerateColumns="False"
                              Background="Transparent" Foreground="White"
                              RowBackground="#FF1A1A2E" BorderThickness="0"
                              IsReadOnly="True" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150"/>
                            <DataGridTextColumn Header="GM" Binding="{Binding GmUsername}" Width="130"/>
                            <DataGridTextColumn Header="Realm" Binding="{Binding RealmId}" Width="60"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="80"/>
                            <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
