<ui:FluentWindow x:Class="AzerothCoreManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:fui="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        xmlns:pages="clr-namespace:AzerothCoreManager.Pages"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="1100" MinHeight="700"
        Width="1400" Height="850"
        Title="AzerothCore Manager">

    <!-- Custom Window Chrome -->
    <Grid>
        <!-- Background Layer -->
        <Image x:Name="BackgroundImage"
               Source="pack://application:,,,/Resources/Assets/Backgrounds/background_wow.jpg"
               Stretch="UniformToFill"
               Panel.ZIndex="-2" />

        <!-- Dark Vignette Overlay -->
        <Border Panel.ZIndex="-1" Background="#CC000000" />

        <!-- Main Content -->
        <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Height="28" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Resources/Assets/Chrome/border_topbar.png"
                                Stretch="Fill" />
                </Grid.Background>

                <!-- App Icon + Title -->
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Assets/Logo/icon_game_wow_small.png"
                           Width="18" Height="18" Margin="0,0,6,0" />
                    <TextBlock Text="AzerothCore Manager"
                               Foreground="White"
                               FontSize="12"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Window Control Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <!-- Settings (Cog) Button -->
                    <Button x:Name="CogButton"
                            Width="28" Height="28"
                            Click="CogButton_Click"
                            ToolTip="Settings">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="CogImage"
                                       Source="pack://application:,,,/Resources/Assets/Chrome/btn_win_cog_normal.png"
                                       Width="28" Height="28" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CogImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_cog_hover.png" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CogImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_cog_pressed.png" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="CogImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_cog_disabled.png" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Minimize Button -->
                    <Button x:Name="MinimizeButton"
                            Width="28" Height="28"
                            Click="MinimizeButton_Click"
                            ToolTip="Minimize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="MinImage"
                                       Source="pack://application:,,,/Resources/Assets/Chrome/btn_win_minimize_normal.png"
                                       Width="28" Height="28" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MinImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_minimize_hover.png" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="MinImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_minimize_pressed.png" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="MinImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_minimize_disabled.png" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Maximize / Restore Button -->
                    <Button x:Name="MaximizeButton"
                            Width="28" Height="28"
                            Click="MaximizeButton_Click"
                            ToolTip="Maximize">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="MaxImage"
                                       Source="pack://application:,,,/Resources/Assets/Chrome/btn_win_maximize_normal.png"
                                       Width="28" Height="28" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="MaxImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_maximize_hover.png" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="MaxImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_maximize_pressed.png" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="MaxImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_maximize_disabled.png" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="CloseButton"
                            Width="28" Height="28"
                            Click="CloseButton_Click"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Image x:Name="CloseImage"
                                       Source="pack://application:,,,/Resources/Assets/Chrome/btn_win_close_normal.png"
                                       Width="28" Height="28" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CloseImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_close_hover.png" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="CloseImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_close_pressed.png" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="CloseImage" Property="Source"
                                                Value="pack://application:,,,/Resources/Assets/Chrome/btn_win_close_disabled.png" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Navigation + Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Navigation View -->
                <ui:NavigationView x:Name="NavView"
                                   Grid.Column="0"
                                   PaneDisplayMode="Left"
                                   IsPaneToggleVisible="True"
                                   IsBackButtonVisible="Collapsed">
                    <ui:NavigationView.MenuItems>
                        <ui:NavigationViewItem x:Name="NavDashboard" Content="Dashboard"
                                              TargetPageType="{x:Type pages:DashboardPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Home24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavSetup" Content="Setup"
                                              TargetPageType="{x:Type pages:SetupPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Wrench24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavServerControl" Content="Server Control"
                                              TargetPageType="{x:Type pages:ServerControlPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Server24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavGmConsole" Content="GM Console"
                                              TargetPageType="{x:Type pages:GmConsolePage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="WindowConsole20" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavModuleManager" Content="Module Manager"
                                              TargetPageType="{x:Type pages:ModuleManagerPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="PuzzlePiece24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavDatabase" Content="Database"
                                              TargetPageType="{x:Type pages:DatabasePage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Database24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavAccounts" Content="Accounts"
                                              TargetPageType="{x:Type pages:AccountsPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="People24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavSettings" Content="Settings"
                                              TargetPageType="{x:Type pages:SettingsPage}">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Settings24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.MenuItems>

                    <!-- Tool Window Buttons in Footer -->
                    <ui:NavigationView.FooterMenuItems>
                        <ui:NavigationViewItem x:Name="NavConfigEditor" Content="Config Editor"
                                              Click="OpenConfigEditor_Click">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Document24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavBackupManager" Content="Backup Manager"
                                              Click="OpenBackupManager_Click">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="Save24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                        <ui:NavigationViewItem x:Name="NavLogViewer" Content="Log Viewer"
                                              Click="OpenLogViewer_Click">
                            <ui:NavigationViewItem.Icon>
                                <ui:SymbolIcon Symbol="SlideText24" />
                            </ui:NavigationViewItem.Icon>
                        </ui:NavigationViewItem>
                    </ui:NavigationView.FooterMenuItems>
                </ui:NavigationView>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Background="#E5000000"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,1,0,0"
                    Height="28">
                <Grid Margin="12,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <!-- Authserver Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Image x:Name="AuthStatusIcon"
                                   Source="pack://application:,,,/Resources/Assets/Icons/icon_offline_32.png"
                                   Width="14" Height="14" Margin="0,0,4,0" />
                            <TextBlock x:Name="AuthStatusText"
                                       Text="Authserver: Offline"
                                       Foreground="#FF888888"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Worldserver Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Image x:Name="WorldStatusIcon"
                                   Source="pack://application:,,,/Resources/Assets/Icons/icon_offline_32.png"
                                   Width="14" Height="14" Margin="0,0,4,0" />
                            <TextBlock x:Name="WorldStatusText"
                                       Text="Worldserver: Offline"
                                       Foreground="#FF888888"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- MySQL Status -->
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="MySqlStatusIcon"
                                   Source="pack://application:,,,/Resources/Assets/Icons/icon_offline_32.png"
                                   Width="14" Height="14" Margin="0,0,4,0" />
                            <TextBlock x:Name="MySqlStatusText"
                                       Text="MySQL: Offline"
                                       Foreground="#FF888888"
                                       FontSize="11"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="PlayerCountText"
                                   Text="Players: 0"
                                   Foreground="#FFAAAAAA"
                                   FontSize="11"
                                   Margin="0,0,16,0"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="VersionText"
                                   Text="v0.1.0"
                                   Foreground="#FF888888"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
