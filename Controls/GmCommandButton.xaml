<UserControl x:Class="AzerothCoreManager.Controls.GmCommandButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button x:Name="CmdButton" Height="32" Padding="10,4"
            Click="CmdButton_Click"
            Background="#FF2D2D5A" Foreground="White"
            BorderBrush="#FF444477" BorderThickness="1">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="CategoryTag" Text="[ ]" FontSize="10" 
                       Foreground="#FF888888" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="CommandLabel" Text="command" FontSize="12" 
                       FontFamily="Consolas" VerticalAlignment="Center"/>
        </StackPanel>
    </Button>
</UserControl>
