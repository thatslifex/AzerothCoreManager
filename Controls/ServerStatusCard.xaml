<UserControl x:Class="AzerothCoreManager.Controls.ServerStatusCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ui:Card Width="280" Margin="0,0,12,12">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header: Icon + Name + Status -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <ui:SymbolIcon x:Name="ServerIcon" Symbol="Server24" 
                               Foreground="White" FontSize="20" Margin="0,0,8,0"/>
                <TextBlock x:Name="ServerName" Text="Server" 
                           FontWeight="SemiBold" Foreground="White" FontSize="16"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusDot" Text="●" FontSize="12" 
                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Offline" FontSize="12"
                           Foreground="#FF888888" Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Uptime -->
            <TextBlock Grid.Row="1" x:Name="UptimeText" Text="Uptime: --"
                       Foreground="#FFAAAAAA" FontSize="12" Margin="0,0,0,8"/>

            <!-- Last output line -->
            <TextBlock Grid.Row="2" x:Name="LastOutput" Text=""
                       Foreground="#FF666666" FontSize="11" FontFamily="Consolas"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,8"
                       MaxHeight="28" TextWrapping="NoWrap"/>

            <!-- Action buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button x:Name="StartButton" Content="Start" Width="70" Height="28"
                        Margin="0,0,6,0" Click="StartButton_Click"/>
                <Button x:Name="StopButton" Content="Stop" Width="70" Height="28"
                        Margin="0,0,6,0" Click="StopButton_Click"/>
                <Button x:Name="RestartButton" Content="Restart" Width="70" Height="28"
                        Click="RestartButton_Click"/>
            </StackPanel>
        </Grid>
    </ui:Card>
</UserControl>
